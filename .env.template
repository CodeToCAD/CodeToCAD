# CodeToCAD Environment Configuration Template
# Copy this file to .env and fill in your API keys and configuration

# =============================================================================
# Asset Management Configuration
# =============================================================================

# Material Asset APIs
# -------------------
# Poliigon API key (premium material service)
# Get your API key from: https://www.poliigon.com/account/api
POLIIGON_API_KEY=your_poliigon_api_key_here

# Thingiverse API key (3D model repository)
# Get your API key from: https://www.thingiverse.com/apps/create
THINGIVERSE_API_KEY=your_thingiverse_api_key_here

# Asset Cache Directories
# -----------------------
# Directory to cache downloaded materials (leave empty for default: ~/.codetocad/material_cache)
MATERIAL_CACHE_DIR=

# Directory to cache downloaded 3D models (leave empty for default: ~/.codetocad/model_cache)
MODEL_CACHE_DIR=

# Asset Download Settings
# ----------------------
# Automatically download materials when referenced (true/false)
AUTO_DOWNLOAD_MATERIALS=true

# Automatically download 3D models when referenced (true/false)
AUTO_DOWNLOAD_MODELS=false

# Maximum cache size in MB (default: 1000)
MAX_CACHE_SIZE_MB=1000

# =============================================================================
# Simulation Configuration
# =============================================================================

# PyBullet Configuration
# ---------------------
# Default GUI mode for PyBullet simulations (true/false)
PYBULLET_DEFAULT_GUI=true

# Default time step for PyBullet simulations (seconds)
PYBULLET_DEFAULT_TIME_STEP=0.004166667

# MuJoCo Configuration
# -------------------
# Default viewer mode for MuJoCo simulations (true/false)
MUJOCO_DEFAULT_VIEWER=true

# Default time step for MuJoCo simulations (seconds)
MUJOCO_DEFAULT_TIME_STEP=0.002

# =============================================================================
# CAD Provider Configuration
# =============================================================================

# Build123d Configuration
# -----------------------
# Path to Build123d installation (leave empty for auto-detection)
BUILD123D_PATH=

# FreeCAD Configuration
# --------------------
# Path to FreeCAD installation (leave empty for auto-detection)
FREECAD_PATH=

# Fusion360 Configuration
# -----------------------
# Fusion360 API credentials (if using Fusion360 adapter)
FUSION360_CLIENT_ID=
FUSION360_CLIENT_SECRET=

# =============================================================================
# Export and File Handling
# =============================================================================

# Default export quality settings
# -------------------------------
# STL export resolution (low/medium/high)
STL_EXPORT_QUALITY=medium

# Default units for exports (mm/cm/m/in/ft)
DEFAULT_EXPORT_UNITS=mm

# Temporary file cleanup (true/false)
AUTO_CLEANUP_TEMP_FILES=true

# =============================================================================
# Development and Debugging
# =============================================================================

# Debug mode (true/false)
DEBUG_MODE=false

# Verbose logging (true/false)
VERBOSE_LOGGING=false

# Log file path (leave empty to disable file logging)
LOG_FILE_PATH=

# =============================================================================
# Network and Performance
# =============================================================================

# Request timeout for API calls (seconds)
API_REQUEST_TIMEOUT=30

# Maximum concurrent downloads
MAX_CONCURRENT_DOWNLOADS=3

# Rate limiting delay between API requests (seconds)
API_RATE_LIMIT_DELAY=1.0

# =============================================================================
# Usage Notes
# =============================================================================

# 1. Copy this file to .env in your project root
# 2. Fill in the API keys you want to use
# 3. Adjust cache directories and settings as needed
# 4. The .env file should NOT be committed to version control
# 5. API keys are optional - the system will work without them using fallback methods
# 6. Free alternatives (like ambientCG) don't require API keys

# Free Material Sources (no API key required):
# - ambientCG: https://ambientcg.com/ (CC0 materials)
# - Poly Haven: https://polyhaven.com/ (CC0 materials)
# - Texture Haven: https://texturehaven.com/ (CC0 materials)

# Free 3D Model Sources (no API key required):
# - Printables: https://www.printables.com/
# - MyMiniFactory: https://www.myminifactory.com/
# - Cults3D: https://cults3d.com/
# - GrabCAD: https://grabcad.com/
